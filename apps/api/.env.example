# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service-role-key...
# JWKS endpoint Supabase exposes for verifying user JWTs (asymmetric, ES256)
SUPABASE_JWT_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
# Optional override (rarely needed). Defaults to <SUPABASE_URL>/auth/v1/.well-known/jwks.json.

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default models. Override per-request via the "model" body field.
OPENROUTER_MODEL_DEFAULT=anthropic/claude-sonnet-4-5
OPENROUTER_MODEL_CHEAP=anthropic/claude-haiku-4-5

# CORS — comma-separated origins for the web PWA
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
